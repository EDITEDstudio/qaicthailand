rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints (The "Anti-Update-Gap")
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('role' in data) || (data.role in ['user', 'admin']));
    }

    // users/{userId}
    match /users/{userId} {
      allow get: if isOwner(userId);
      // Only the user themselves can create their profile, and they can't set their own role to admin (unless it's the admin email)
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().uid == userId &&
                      (incoming().role == 'user' || incoming().email == 'admin@qaic-thailand.com'); // Allow admin registration
      
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().uid == userId &&
                      (incoming().role == existing().role || incoming().email == 'admin@qaic-thailand.com') && // Prevent changing own role unless admin email
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    match /certificates/{certId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if false; // System only
    }

    match /audits/{auditId} {
      allow read: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['documentUploadedAt', 'updatedAt']);
      allow create, delete: if false; // System only
    }

    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
